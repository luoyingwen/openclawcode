{
  "name": "@grinev/openclaw-opencode-plugin",
  "version": "0.1.0",
  "description": "OpenClaw plugin for OpenCode integration - intercept channel messages and route to OpenCode",
  "type": "module",
  "main": "./dist/openclaw-plugin.js",
  "exports": {
    ".": "./dist/openclaw-plugin.js"
  },
  "openclaw": {
    "extensions": [
      "./dist/openclaw-plugin.js"
    ],
    "plugin": {
      "id": "openclawcode",
      "enabledByDefault": false
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src --ext .ts --max-warnings=0",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luoyingwen/openclawcode.git"
  },
  "keywords": [
    "opencode",
    "openclaw",
    "openclaw-plugin",
    "ai-coding"
  ],
  "author": "luoyingwen",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/luoyingwen/openclawcode/issues"
  },
  "homepage": "https://github.com/luoyingwen/openclawcode#readme",
  "dependencies": {
    "@opencode-ai/sdk": "^1.1.21",
    "openclaw": ">=2025.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.8",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "openclaw": ">=2025.0.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": false
    }
  }
}