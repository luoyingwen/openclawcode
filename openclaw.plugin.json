{
  "id": "openclawcode",
  "name": "OpenClawCode",
  "description": "OpenClaw plugin for OpenCode - intercept channel messages and route to OpenCode server",
  "enabledByDefault": false,
  "installDependencies": true,
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "description": "Enable the OpenCode channel command plugin"
      },
      "channels": {
        "type": "array",
        "description": "Channel IDs to intercept (empty = all)",
        "items": {
          "type": "string"
        }
      },
      "accountIds": {
        "type": "array",
        "description": "Account IDs to intercept (empty = all)",
        "items": {
          "type": "string"
        }
      },
      "conversationIds": {
        "type": "array",
        "description": "Conversation IDs to intercept (empty = all)",
        "items": {
          "type": "string"
        }
      },
      "opencodeBaseUrl": {
        "type": "string",
        "description": "OpenCode server URL (default: http://localhost:4096)"
      },
      "opencodeUsername": {
        "type": "string",
        "description": "OpenCode auth username"
      },
      "opencodePassword": {
        "type": "string",
        "description": "OpenCode auth password"
      },
      "defaultProjectDirectory": {
        "type": "string",
        "description": "Default OpenCode project directory"
      }
    }
  }
}